# Required backend connection settings
BACKEND_API_BASE_URL=https://api.example
BACKEND_API_OPEN_TIMEOUT=2
BACKEND_API_READ_TIMEOUT=5

# Optional: contract mismatch artifact directory (used by CI/diagnostics)
BFF_CONTRACT_DIFF_DIR=tmp/contract_diffs

# Optional: app runtime tuning
RAILS_MAX_THREADS=3
PORT=3000
RAILS_LOG_LEVEL=info
SOLID_QUEUE_IN_PUMA=false
