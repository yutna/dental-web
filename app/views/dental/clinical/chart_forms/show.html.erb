<turbo-frame id="clinical_form">
  <div class="rounded-2xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm">
    <div class="mb-5">
      <h2 class="text-lg font-semibold text-app-text-primary"><%= t("dental.clinical.chart.heading") %></h2>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("dental.clinical.chart.description") %></p>
    </div>

    <% charts = @result[:payload].is_a?(Hash) ? (@result.dig(:payload, "charts") || @result.dig(:payload, :charts) || []) : [] %>
    <% conditions = charts.each_with_object({}) { |c, h| h[c["tooth_code"] || c[:tooth_code]] = (c["charting_code"] || c[:charting_code]).to_s.downcase.gsub("caries", "problematic").gsub("filling", "treated").gsub("crown", "planned") } %>

    <%= form_with url: dental_clinical_chart_form_path(visit_id: @visit_id), method: :patch, class: "space-y-6", data: { turbo: false } do |f| %>
      <% if @queue_entry %>
        <%= f.hidden_field :patient_hn, value: @queue_entry.mrn %>
      <% end %>

      <%# Visual tooth chart %>
      <%= render "components/tooth_chart", selected: [], conditions: conditions, multi_select: true, read_only: false, name: "selected_teeth" %>

      <%# Existing chart entries %>
      <% if charts.any? %>
        <div class="overflow-x-auto rounded-xl border border-app-border-primary">
          <table class="min-w-full divide-y divide-app-border-primary text-sm">
            <thead class="bg-app-surface-secondary">
              <tr>
                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary">#</th>
                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.chart.table.tooth") %></th>
                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.chart.table.charting_code") %></th>
                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.chart.table.surface") %></th>
                <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.chart.table.note") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-app-border-primary bg-app-surface-primary">
              <% charts.each_with_index do |chart, idx| %>
                <tr>
                  <td class="whitespace-nowrap px-3 py-2 text-app-text-tertiary"><%= idx + 1 %></td>
                  <td class="whitespace-nowrap px-3 py-2 font-medium text-app-text-primary"><%= chart["tooth_code"] || chart[:tooth_code] %></td>
                  <td class="whitespace-nowrap px-3 py-2 text-app-text-secondary"><%= chart["charting_code"] || chart[:charting_code] %></td>
                  <td class="whitespace-nowrap px-3 py-2 text-app-text-secondary"><%= Array(chart["surface_codes"] || chart[:surface_codes]).join(", ") %></td>
                  <td class="px-3 py-2 text-app-text-tertiary"><%= chart["note"] || chart[:note] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>

      <%# Add chart entry %>
      <fieldset class="rounded-xl border border-app-border-primary p-4">
        <legend class="px-2 text-sm font-semibold text-app-text-primary"><%= t("dental.clinical.chart.add_entry") %></legend>
        <div class="mt-2 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <label for="chart_tooth" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.chart.form.tooth") %></label>
            <input type="text" name="charts[][tooth_code]" id="chart_tooth" required
              placeholder="16" class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
          <div>
            <label for="chart_code" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.chart.form.charting_code") %></label>
            <input type="text" name="charts[][charting_code]" id="chart_code" required
              placeholder="CARIES" class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
          <div>
            <label for="chart_surface" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.chart.form.surface") %></label>
            <input type="text" name="charts[][surface_codes]" id="chart_surface"
              placeholder="O,M" class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
          <div>
            <label for="chart_note" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.chart.form.note") %></label>
            <input type="text" name="charts[][note]" id="chart_note"
              class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
        </div>
      </fieldset>

      <%# Sticky save bar %>
      <div class="z-app-sticky sticky bottom-0 flex items-center justify-end gap-3 border-t border-app-border-primary bg-app-surface-primary px-1 py-4">
        <%= link_to t("dental.clinical.chart.actions.back"), dental_clinical_workspace_path(visit_id: @visit_id, tab: "chart"),
          class: "rounded-lg border border-app-border-primary bg-app-surface-secondary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-primary" %>
        <button type="submit" class="rounded-lg bg-app-brand-primary px-6 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active">
          <%= t("dental.clinical.chart.actions.save") %>
        </button>
      </div>
    <% end %>
  </div>
</turbo-frame>
