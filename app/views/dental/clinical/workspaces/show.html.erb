<% content_for :title, t("dental.clinical.workspace.title", id: @visit_id) %>
<% set_breadcrumbs(
  { label: t("layouts.sidebar.nav.workspace"), path: workspace_path },
  { label: @visit_id, path: dental_visit_path(id: @visit_id) },
  { label: t("layouts.sidebar.nav.clinical") }
) %>

<div class="flex flex-col gap-4 p-4 lg:flex-row lg:items-start lg:p-6">
  <%# Left column — Patient context card (sticky on desktop) %>
  <aside class="w-full shrink-0 lg:sticky lg:top-4 lg:w-72 xl:w-80">
    <div class="rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
      <%# Patient header %>
      <div class="border-b border-app-border-primary p-4">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-app-brand-primary/10 text-sm font-bold text-app-brand-primary">
            <%= @queue_entry&.patient_name&.first&.upcase || "?" %>
          </div>
          <div class="min-w-0">
            <h2 class="truncate text-base font-semibold text-app-text-primary"><%= @queue_entry&.patient_name || t("dental.clinical.history.unknown") %></h2>
            <p class="text-xs text-app-text-tertiary">HN: <span class="tabular-nums"><%= @queue_entry&.mrn || "—" %></span></p>
          </div>
        </div>
      </div>

      <%# Visit details %>
      <dl class="divide-y divide-app-border-primary text-sm">
        <div class="flex items-center justify-between px-4 py-2.5">
          <dt class="text-app-text-tertiary"><%= t("dental.clinical.workspace.visit_id_label") %></dt>
          <dd class="font-medium tabular-nums text-app-text-primary"><%= @visit_id %></dd>
        </div>
        <div class="flex items-center justify-between px-4 py-2.5">
          <dt class="text-app-text-tertiary"><%= t("dental.clinical.workspace.stage_label") %></dt>
          <dd>
            <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-semibold <%= visit_stage_classes(@snapshot[:current_stage]) %>">
              <%= t("dental.enums.visit_stage.#{@snapshot[:current_stage]}") %>
            </span>
          </dd>
        </div>
        <% if @queue_entry&.service.present? %>
          <div class="flex items-center justify-between px-4 py-2.5">
            <dt class="text-app-text-tertiary"><%= t("dental.clinical.workspace.service_label") %></dt>
            <dd class="text-app-text-primary"><%= @queue_entry.service %></dd>
          </div>
        <% end %>
        <% if @queue_entry&.dentist.present? %>
          <div class="flex items-center justify-between px-4 py-2.5">
            <dt class="text-app-text-tertiary"><%= t("dental.clinical.workspace.dentist_label") %></dt>
            <dd class="text-app-text-primary"><%= @queue_entry.dentist %></dd>
          </div>
        <% end %>
        <div class="flex items-center justify-between px-4 py-2.5">
          <dt class="text-app-text-tertiary"><%= t("dental.clinical.workspace.lock_version_label") %></dt>
          <dd class="rounded bg-app-surface-secondary px-1.5 py-0.5 text-xs tabular-nums text-app-text-secondary">v<%= @snapshot[:lock_version] %></dd>
        </div>
      </dl>

      <%# Quick actions %>
      <div class="border-t border-app-border-primary p-4">
        <%= link_to dental_visit_path(id: @visit_id),
          class: "flex w-full items-center justify-center gap-2 rounded-lg border border-app-border-primary bg-app-surface-secondary px-3 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-primary" do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"/></svg>
          <%= t("dental.clinical.workspace.back_to_visit") %>
        <% end %>
      </div>
    </div>
  </aside>

  <%# Right column — Tabs + form content %>
  <main class="min-w-0 flex-1 space-y-4">
    <%# Tab navigation %>
    <nav class="flex gap-1 overflow-x-auto rounded-xl border border-app-border-primary bg-app-surface-primary p-1 shadow-sm" aria-label="<%= t("dental.clinical.workspace.tabs_label") %>">
      <% %w[screening treatment medication chart images history].each do |tab| %>
        <% active = @tab == tab %>
        <%= link_to t("dental.clinical.tabs.#{tab}"),
          dental_clinical_workspace_path(visit_id: @visit_id, tab: tab),
          class: "rounded-lg px-4 py-2 text-sm font-medium transition whitespace-nowrap #{active ? 'bg-app-brand-primary text-app-brand-inverse shadow-sm' : 'text-app-text-secondary hover:bg-app-surface-secondary hover:text-app-text-primary'}",
          "aria-current": (active ? "page" : nil) %>
      <% end %>
    </nav>

    <%# Tab content with lazy-loaded Turbo frame %>
    <section>
      <% tab_paths = {
        "screening"  => dental_clinical_screening_form_path(visit_id: @visit_id),
        "treatment"  => dental_clinical_treatment_form_path(visit_id: @visit_id),
        "medication" => dental_clinical_medication_form_path(visit_id: @visit_id),
        "chart"      => dental_clinical_chart_form_path(visit_id: @visit_id),
        "images"     => dental_clinical_image_form_path(visit_id: @visit_id),
        "history"    => dental_clinical_history_drawer_path(visit_id: @visit_id)
      } %>
      <turbo-frame id="clinical_form" src="<%= tab_paths[@tab] %>" loading="lazy">
        <div class="rounded-xl border border-app-border-primary bg-app-surface-primary p-8">
          <div class="animate-pulse space-y-4">
            <div class="h-4 w-1/3 rounded bg-app-surface-secondary"></div>
            <div class="h-10 rounded bg-app-surface-secondary"></div>
            <div class="h-10 rounded bg-app-surface-secondary"></div>
            <div class="h-10 rounded bg-app-surface-secondary"></div>
          </div>
        </div>
      </turbo-frame>
    </section>
  </main>
</div>
