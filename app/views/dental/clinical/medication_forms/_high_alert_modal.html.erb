<%# High-alert medication confirmation modal (state-11) %>
<%= render layout: "components/modal", locals: { id: "high-alert-modal", title: t("dental.clinical.medication.high_alert_modal.title"), size: "md" } do %>
  <div class="space-y-4">
    <dl class="space-y-2 text-sm">
      <div class="flex gap-2">
        <dt class="font-medium text-app-text-secondary"><%= t("dental.clinical.medication.high_alert_modal.item_label") %>:</dt>
        <dd class="text-app-text-primary" data-medication-form-target="modalItemName">—</dd>
      </div>
      <div class="flex gap-2">
        <dt class="font-medium text-app-text-secondary"><%= t("dental.clinical.medication.high_alert_modal.category_label") %>:</dt>
        <dd class="font-semibold text-text-semantic-warning-primary"><%= t("dental.clinical.medication.high_alert_modal.category_value") %></dd>
      </div>
      <div class="flex gap-2">
        <dt class="font-medium text-app-text-secondary"><%= t("dental.clinical.medication.high_alert_modal.patient_label") %>:</dt>
        <dd class="text-app-text-primary"><%= @queue_entry&.patient_name || @queue_entry&.mrn || "—" %></dd>
      </div>
    </dl>

    <p class="rounded-lg border border-border-semantic-warning-primary bg-bg-semantic-warning-default p-3 text-sm text-text-semantic-warning-primary">
      <%= t("dental.clinical.medication.high_alert_modal.warning_text") %>
    </p>

    <div class="flex items-center justify-end gap-3 border-t border-app-border-primary pt-4">
      <button type="button" data-action="modal#close medication-form#cancelHighAlert"
        class="rounded-lg border border-app-border-primary bg-app-surface-secondary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-primary">
        <%= t("dental.clinical.medication.high_alert_modal.cancel") %>
      </button>
      <button type="button" data-action="medication-form#confirmHighAlert"
        class="rounded-lg bg-bg-semantic-warning-default px-6 py-2 text-sm font-semibold text-text-semantic-warning-primary transition hover:opacity-90">
        <%= t("dental.clinical.medication.high_alert_modal.confirm") %>
      </button>
    </div>
  </div>
<% end %>
