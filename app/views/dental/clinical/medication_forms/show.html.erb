<turbo-frame id="clinical_form">
  <div class="rounded-2xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm" data-controller="medication-form">
    <div class="mb-5">
      <h2 class="text-lg font-semibold text-app-text-primary"><%= t("dental.clinical.medication.heading") %></h2>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("dental.clinical.medication.description") %></p>
    </div>

    <% medications = @result[:data].is_a?(Hash) ? (@result.dig(:data, "medications") || @result.dig(:data, :medications) || []) : [] %>
    <% allergies = @result[:data].is_a?(Hash) ? (@result.dig(:data, "allergies") || @result.dig(:data, :allergies) || []) : [] %>

    <%# Allergy alert %>
    <% if allergies.any? %>
      <div class="mb-5 rounded-xl border border-border-semantic-error-primary bg-bg-semantic-error-default p-4" role="alert">
        <h3 class="text-sm font-semibold text-text-semantic-error-primary"><%= t("dental.clinical.medication.allergy_alert.heading") %></h3>
        <ul class="mt-2 space-y-1">
          <% allergies.each do |allergy| %>
            <li class="text-sm text-text-semantic-error-primary">
              <%= allergy["medication_code"] || allergy[:medication_code] %> — <%= allergy["reaction"] || allergy[:reaction] %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Existing medications table %>
    <% if medications.any? %>
      <div class="overflow-x-auto rounded-xl border border-app-border-primary">
        <table class="min-w-full divide-y divide-app-border-primary text-sm">
          <thead class="bg-app-surface-secondary">
            <tr>
              <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary">#</th>
              <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.medication.table.medication_code") %></th>
              <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.medication.table.quantity") %></th>
              <th class="whitespace-nowrap px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("dental.clinical.medication.table.note") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-app-border-primary bg-app-surface-primary">
            <% medications.each_with_index do |med, idx| %>
              <tr>
                <td class="whitespace-nowrap px-3 py-2 text-app-text-tertiary"><%= idx + 1 %></td>
                <td class="whitespace-nowrap px-3 py-2 font-medium text-app-text-primary"><%= med["medication_code"] || med[:medication_code] %></td>
                <td class="whitespace-nowrap px-3 py-2 text-app-text-secondary"><%= med["quantity"] || med[:quantity] %></td>
                <td class="px-3 py-2 text-app-text-tertiary"><%= med["note"] || med[:note] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <%# Add medication form %>
    <div class="mt-6">
      <h3 class="text-sm font-semibold text-app-text-primary"><%= t("dental.clinical.medication.add_medication") %></h3>
      <%= form_with url: dental_clinical_medication_form_path(visit_id: @visit_id), method: :patch, class: "mt-3 space-y-4", data: { turbo: false, medication_form_target: "form" } do |f| %>
        <% if @queue_entry %>
          <%= f.hidden_field :patient_hn, value: @queue_entry.mrn %>
        <% end %>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="med_code" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.medication.form.medication_code") %></label>
            <input type="text" name="medications[][medication_code]" id="med_code" required
              placeholder="DIAZEPAM-5MG" data-medication-form-target="codeInput" data-action="change->medication-form#checkHighAlert"
              class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
          <div>
            <label for="med_qty" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.medication.form.quantity") %></label>
            <input type="number" name="medications[][quantity]" id="med_qty" value="1" min="1"
              class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
          <div>
            <label for="med_note" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.medication.form.note") %></label>
            <input type="text" name="medications[][note]" id="med_note"
              placeholder="1 tab nightly x 5 days"
              class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
        </div>

        <%# High-alert confirmation field (hidden until needed) %>
        <div class="hidden rounded-xl border border-border-semantic-warning-primary bg-bg-semantic-warning-default p-4" data-medication-form-target="highAlertPanel" role="alert">
          <h4 class="text-sm font-semibold text-text-semantic-warning-primary"><%= t("dental.clinical.medication.high_alert.heading") %></h4>
          <p class="mt-1 text-sm text-text-semantic-warning-primary/90"><%= t("dental.clinical.medication.high_alert.description") %></p>
          <label class="mt-3 flex items-center gap-2">
            <input type="checkbox" name="confirm_high_alert" value="true" data-medication-form-target="highAlertCheckbox"
              class="form-checkbox border-border-semantic-warning-primary text-text-semantic-warning-primary focus:ring-border-semantic-warning-primary">
            <span class="text-sm font-medium text-text-semantic-warning-primary"><%= t("dental.clinical.medication.high_alert.confirm_label") %></span>
          </label>
        </div>

        <%# Allergy override reason (hidden until needed) %>
        <div class="hidden rounded-xl border border-border-semantic-error-primary bg-bg-semantic-error-default p-4" data-medication-form-target="allergyPanel" role="alert">
          <h4 class="text-sm font-semibold text-text-semantic-error-primary"><%= t("dental.clinical.medication.allergy_warning.heading") %></h4>
          <p class="mt-1 text-sm text-text-semantic-error-primary/90"><%= t("dental.clinical.medication.allergy_warning.description") %></p>
          <div class="mt-3">
            <label for="allergy_override" class="block text-sm font-medium text-text-semantic-error-primary"><%= t("dental.clinical.medication.allergy_warning.override_label") %></label>
            <input type="text" name="allergy_override_reason" id="allergy_override" data-medication-form-target="allergyReasonInput"
              class="form-input mt-1 block w-full border-border-semantic-error-primary bg-app-surface-primary text-app-text-primary focus:border-border-semantic-error-primary focus:ring-border-semantic-error-primary">
          </div>
        </div>

        <div class="flex items-center justify-end gap-3">
          <%= link_to t("dental.clinical.medication.actions.back"), dental_clinical_workspace_path(visit_id: @visit_id, tab: "medication"),
            class: "rounded-lg border border-app-border-primary bg-app-surface-secondary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-primary" %>
          <button type="submit" class="rounded-lg bg-app-brand-primary px-6 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active">
            <%= t("dental.clinical.medication.actions.save") %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
