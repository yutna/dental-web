<turbo-frame id="clinical_form">
<section class="space-y-6 rounded-2xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm">
  <header class="space-y-2">
    <h1 class="text-xl font-semibold text-app-text-primary"><%= t("dental.clinical.history.title") %></h1>
    <p class="text-sm text-app-text-secondary">
      <%= t("dental.clinical.history.patient") %>: <%= @history[:patient_hn].presence || t("dental.clinical.history.unknown") %>
    </p>
  </header>

  <%# Cumulative tooth map (read-only) %>
  <% tooth_conditions = @history[:tooth_map].each_with_object({}) do |row, h|
    code = row["tooth_code"]
    if row["procedure_count"].to_i > 0
      h[code] = "treated"
    elsif row["chart_count"].to_i > 0
      h[code] = "problematic"
    end
  end %>

  <details class="rounded-xl border border-app-border-primary bg-app-surface-primary p-4" open>
    <summary class="cursor-pointer text-sm font-medium text-app-text-primary"><%= t("dental.clinical.history.tooth_map") %></summary>
    <div class="mt-4">
      <%= render "components/tooth_chart", selected: [], conditions: tooth_conditions, multi_select: false, read_only: true, name: "history_teeth" %>
    </div>
  </details>

  <%# Visit timeline %>
  <details class="rounded-xl border border-app-border-primary bg-app-surface-primary p-4" open>
    <summary class="cursor-pointer text-sm font-medium text-app-text-primary"><%= t("dental.clinical.history.timeline") %></summary>
    <div class="mt-4">
      <% if @history[:timeline].any? %>
        <ol class="relative border-l-2 border-app-border-primary pl-6">
          <% @history[:timeline].each do |entry| %>
            <li class="mb-4 last:mb-0">
              <span class="absolute -left-1.5 mt-1.5 h-3 w-3 rounded-full border-2 border-app-surface-primary bg-app-brand-primary"></span>
              <div class="rounded-lg bg-app-surface-secondary p-3">
                <div class="flex items-center gap-2">
                  <span class="inline-flex rounded-md bg-app-surface-tertiary px-2 py-0.5 text-xs font-semibold text-app-text-secondary"><%= entry["entry_type"] %></span>
                  <span class="text-sm font-medium text-app-text-primary"><%= entry["code"] %></span>
                </div>
                <% if entry["tooth_code"].present? %>
                  <p class="mt-1 text-xs text-app-text-secondary">
                    <%= t("dental.clinical.history.tooth_label") %>: <%= entry["tooth_code"] %>
                    <% if entry["surface_codes"].present? %>
                      · <%= Array(entry["surface_codes"]).join(", ") %>
                    <% end %>
                  </p>
                <% end %>
                <p class="mt-1 text-xs text-app-text-tertiary"><%= entry["occurred_at"] %></p>
              </div>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-sm text-app-text-tertiary"><%= t("dental.clinical.history.no_entries") %></p>
      <% end %>
    </div>
  </details>

  <%# Tooth map summary table %>
  <% if @history[:tooth_map].any? %>
    <details class="rounded-xl border border-app-border-primary bg-app-surface-primary p-4">
      <summary class="cursor-pointer text-sm font-medium text-app-text-primary"><%= t("dental.clinical.history.tooth_summary") %></summary>
      <div class="mt-4 overflow-x-auto">
        <table class="min-w-full divide-y divide-app-border-primary text-sm">
          <thead class="bg-app-surface-secondary">
            <tr>
              <th class="whitespace-nowrap px-4 py-2 text-left text-xs font-semibold uppercase text-app-text-secondary"><%= t("dental.clinical.history.tooth_code") %></th>
              <th class="whitespace-nowrap px-4 py-2 text-left text-xs font-semibold uppercase text-app-text-secondary"><%= t("dental.clinical.history.chart_count") %></th>
              <th class="whitespace-nowrap px-4 py-2 text-left text-xs font-semibold uppercase text-app-text-secondary"><%= t("dental.clinical.history.procedure_count") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-app-border-primary">
            <% @history[:tooth_map].each do |row| %>
              <tr>
                <td class="whitespace-nowrap px-4 py-2 font-medium text-app-text-primary"><%= row["tooth_code"] %></td>
                <td class="whitespace-nowrap px-4 py-2 text-app-text-secondary"><%= row["chart_count"] %></td>
                <td class="whitespace-nowrap px-4 py-2 text-app-text-secondary"><%= row["procedure_count"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </details>
  <% end %>
</section>
</turbo-frame>
