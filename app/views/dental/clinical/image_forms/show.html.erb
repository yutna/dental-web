<turbo-frame id="clinical_form">
  <div class="rounded-2xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm" data-controller="image-preview">
    <div class="mb-5">
      <h2 class="text-lg font-semibold text-app-text-primary"><%= t("dental.clinical.images.heading") %></h2>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("dental.clinical.images.description") %></p>
    </div>

    <% images = @result[:payload].is_a?(Hash) ? (@result.dig(:payload, "images") || @result.dig(:payload, :images) || []) : [] %>

    <%# Existing images gallery %>
    <% if images.any? %>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <% images.each do |img| %>
          <div class="overflow-hidden rounded-xl border border-app-border-primary bg-app-surface-secondary">
            <div class="flex h-32 items-center justify-center bg-app-surface-tertiary text-app-text-tertiary">
              <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
              </svg>
            </div>
            <div class="p-3">
              <p class="text-sm font-medium text-app-text-primary"><%= img["image_type_code"] || img[:image_type_code] %></p>
              <p class="text-xs text-app-text-tertiary"><%= img["image_ref"] || img[:image_ref] %></p>
              <% if (note = img["note"] || img[:note]).present? %>
                <p class="mt-1 text-xs text-app-text-secondary"><%= note %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Upload form %>
    <div class="mt-6">
      <h3 class="text-sm font-semibold text-app-text-primary"><%= t("dental.clinical.images.add_image") %></h3>
      <%= form_with url: dental_clinical_image_form_path(visit_id: @visit_id), method: :patch, class: "mt-3 space-y-4", data: { turbo: false } do |f| %>
        <% if @queue_entry %>
          <%= f.hidden_field :patient_hn, value: @queue_entry.mrn %>
        <% end %>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="img_type" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.images.form.type") %></label>
            <select name="images[][image_type_code]" id="img_type" required
              class="form-select mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary focus:border-app-brand-primary focus:ring-app-brand-primary">
              <option value="XRAY"><%= t("dental.clinical.images.types.xray") %></option>
              <option value="PHOTO"><%= t("dental.clinical.images.types.photo") %></option>
              <option value="DICOM"><%= t("dental.clinical.images.types.dicom") %></option>
            </select>
          </div>
          <div>
            <label for="img_ref" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.images.form.reference") %></label>
            <input type="text" name="images[][image_ref]" id="img_ref" required
              placeholder="IMG-2026-001" class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
          <div>
            <label for="img_note" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.images.form.note") %></label>
            <input type="text" name="images[][note]" id="img_note"
              class="form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
          </div>
        </div>

        <%# File upload with preview %>
        <div>
          <label for="img_file" class="block text-sm font-medium text-app-text-secondary"><%= t("dental.clinical.images.form.file") %></label>
          <div class="mt-1 flex items-center gap-4">
            <input type="file" name="images[][file]" id="img_file" accept="image/png,image/jpeg,image/webp"
              data-action="change->image-preview#preview" data-image-preview-target="input"
              class="form-input block w-full border-app-border-primary bg-app-surface-primary text-sm text-app-text-primary file:mr-3 file:rounded-lg file:border-0 file:bg-app-brand-primary file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-app-brand-inverse">
            <div data-image-preview-target="preview" class="hidden h-16 w-16 shrink-0 overflow-hidden rounded-lg border border-app-border-primary">
              <img data-image-preview-target="img" alt="Preview" class="h-full w-full object-cover">
            </div>
          </div>
          <p class="mt-1 text-xs text-app-text-tertiary"><%= t("dental.clinical.images.form.file_hint") %></p>
        </div>

        <%# Sticky save bar %>
        <div class="z-app-sticky sticky bottom-0 flex items-center justify-end gap-3 border-t border-app-border-primary bg-app-surface-primary px-1 py-4">
          <%= link_to t("dental.clinical.images.actions.back"), dental_clinical_workspace_path(visit_id: @visit_id, tab: "images"),
            class: "rounded-lg border border-app-border-primary bg-app-surface-secondary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-primary" %>
          <button type="submit" class="rounded-lg bg-app-brand-primary px-6 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active">
            <%= t("dental.clinical.images.actions.save") %>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
