<% content_for :title, t("dental.billing.waiting.title") %>

<div class="p-6">
  <header class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-app-text-primary"><%= t("dental.billing.waiting.heading") %></h1>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("dental.billing.waiting.description") %></p>
    </div>
    <div class="text-xs text-app-text-tertiary">
      <%= t("dental.billing.waiting.auto_refresh") %>
    </div>
  </header>

  <div class="mt-6 overflow-x-auto rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
    <table class="min-w-full divide-y divide-app-border-primary">
      <thead class="bg-app-surface-secondary">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-app-text-tertiary"><%= t("dental.billing.waiting.columns.visit") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-app-text-tertiary"><%= t("dental.billing.waiting.columns.patient") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-app-text-tertiary"><%= t("dental.billing.waiting.columns.invoice_id") %></th>
          <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-app-text-tertiary"><%= t("dental.billing.waiting.columns.amount") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-app-text-tertiary"><%= t("dental.billing.waiting.columns.payment_status") %></th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-app-text-tertiary"><%= t("dental.billing.waiting.columns.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary">
        <% @invoices.each do |invoice| %>
          <tr>
            <td class="whitespace-nowrap px-4 py-3 text-sm text-app-text-primary"><%= invoice.visit_id %></td>
            <td class="whitespace-nowrap px-4 py-3 text-sm text-app-text-primary"><%= invoice.patient_name %></td>
            <td class="whitespace-nowrap px-4 py-3 text-sm font-mono text-app-text-secondary"><%= invoice.invoice_id %></td>
            <td class="whitespace-nowrap px-4 py-3 text-right text-sm text-app-text-primary"><%= number_with_delimiter(invoice.total_amount.to_f, delimiter: ",") %></td>
            <td class="whitespace-nowrap px-4 py-3 text-sm">
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                <%= invoice.pending? ? 'bg-yellow-100 text-yellow-800' : 'bg-green-100 text-green-800' %>">
                <%= invoice.payment_status.upcase %>
              </span>
            </td>
            <td class="whitespace-nowrap px-4 py-3 text-sm">
              <% if invoice.pending? %>
                <%= button_to t("dental.billing.waiting.sync_now"),
                      dental_billing_waiting_sync_path(invoice_id: invoice.invoice_id),
                      method: :post,
                      class: "text-sm font-medium text-app-brand-primary hover:text-app-brand-hover" %>
              <% end %>
            </td>
          </tr>
        <% end %>

        <% if @invoices.empty? %>
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-sm text-app-text-tertiary">
              <%= t("dental.billing.waiting.empty") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
