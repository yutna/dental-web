<% content_for :title, t("dental.visits.title", id: @visit_id) %>
<% set_breadcrumbs(
  { label: t("layouts.sidebar.nav.workspace"), path: workspace_path },
  { label: t("dental.visits.heading", id: @visit_id) }
) %>

<div class="space-y-6 p-6">
  <%# Visit header card %>
  <div class="rounded-xl border border-app-border-primary bg-app-surface-primary p-6 shadow-sm">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-xl font-bold text-app-text-primary"><%= @visit_id %></h1>
          <%= render "components/status_badge", label: t("dental.enums.visit_stage.#{@snapshot[:current_stage]}"), status: @snapshot[:current_stage] %>
          <span class="text-xs text-app-text-tertiary">v<%= @snapshot[:lock_version] %></span>
        </div>
        <% if @queue_entry %>
          <p class="mt-2 text-sm text-app-text-secondary">
            <span class="font-medium text-app-text-primary"><%= @queue_entry.patient_name %></span>
            · HN: <%= @queue_entry.mrn %> · <%= @queue_entry.service %>
            <% if @queue_entry.dentist.present? %>
              · Dr. <%= @queue_entry.dentist %>
            <% end %>
          </p>
        <% end %>
      </div>
      <% if %w[screening ready-for-treatment in-treatment].include?(@snapshot[:current_stage]) %>
        <%= link_to t("dental.visits.clinical.open_forms"),
          dental_clinical_screening_form_path(visit_id: @visit_id),
          class: "inline-flex items-center gap-2 rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
      <% end %>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_20rem]">
    <section class="space-y-6">
      <%# Stage actions %>
      <% if @allowed_transitions.any? %>
        <div class="rounded-xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm">
          <h2 class="text-base font-semibold text-app-text-primary"><%= t("dental.visits.actions.heading") %></h2>
          <p class="mt-1 text-sm text-app-text-secondary"><%= t("dental.visits.actions.description") %></p>

          <div class="mt-4 flex flex-wrap gap-2">
            <% @allowed_transitions.each do |target_stage| %>
              <%= form_with url: dental_visit_transition_path(id: @visit_id), method: :patch, class: "inline-flex", data: { turbo: false } do |f| %>
                <%= f.hidden_field :from_stage, value: @snapshot[:current_stage] %>
                <%= f.hidden_field :to_stage, value: target_stage %>
                <%= f.hidden_field :lock_version, value: @snapshot[:lock_version] %>
                <% if target_stage == "screening" %>
                  <%= f.hidden_field :room_available, value: true %>
                <% end %>
                <% if target_stage == "in-treatment" %>
                  <%= f.hidden_field :dentist_id, value: current_principal.id %>
                <% end %>
                <% if target_stage == "ready-for-treatment" %>
                  <input type="hidden" name="vitals[blood_pressure]" value="120/80">
                  <input type="hidden" name="vitals[pulse]" value="72">
                  <input type="hidden" name="vitals[weight]" value="60">
                <% end %>
                <%= f.submit t("dental.visits.actions.transition_to", stage: t("dental.enums.visit_stage.#{target_stage}")),
                  class: "rounded-lg px-4 py-2 text-sm font-medium transition cursor-pointer #{visit_transition_button_classes(target_stage)}" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Clinical forms quick links %>
      <% if %w[screening ready-for-treatment in-treatment].include?(@snapshot[:current_stage]) %>
        <div class="rounded-xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm">
          <h2 class="text-base font-semibold text-app-text-primary"><%= t("dental.visits.clinical.heading") %></h2>
          <p class="mt-1 text-sm text-app-text-secondary"><%= t("dental.visits.clinical.description") %></p>
          <div class="mt-4 flex flex-wrap gap-2">
            <% %w[screening treatment medication chart images].each do |tab| %>
              <%= link_to t("dental.clinical.tabs.#{tab}"),
                dental_clinical_workspace_path(visit_id: @visit_id, tab: tab),
                class: "inline-flex items-center rounded-lg border border-app-border-primary bg-app-surface-secondary px-3 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-primary" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>

    <%# Timeline sidebar %>
    <aside class="rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
      <div class="border-b border-app-border-primary px-5 py-4">
        <h3 class="text-base font-semibold text-app-text-primary"><%= t("dental.visits.timeline.heading") %></h3>
      </div>
      <div class="p-5">
        <% if @timeline.any? %>
          <ol class="relative space-y-4 border-l-2 border-app-border-primary pl-5">
            <% @timeline.each do |entry| %>
              <li class="relative">
                <div class="absolute -left-[1.625rem] top-1 h-3 w-3 rounded-full border-2 border-app-brand-primary bg-app-surface-primary"></div>
                <p class="text-sm font-medium text-app-text-primary">
                  <%= t("dental.enums.visit_stage.#{entry.from_stage}") %> → <%= t("dental.enums.visit_stage.#{entry.to_stage}") %>
                </p>
                <p class="mt-0.5 text-xs text-app-text-tertiary"><%= l(entry.created_at, format: :short) rescue entry.created_at %></p>
              </li>
            <% end %>
          </ol>
        <% else %>
          <p class="text-sm text-app-text-tertiary"><%= t("dental.visits.timeline.empty") %></p>
        <% end %>
      </div>
    </aside>
  </div>
</div>
