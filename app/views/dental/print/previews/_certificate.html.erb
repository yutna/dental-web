<section class="rounded-md border border-gray-300 bg-white p-10 shadow-sm print:border-none print:shadow-none">
  <header class="print-header text-center">
    <h2 class="text-2xl font-bold text-gray-900"><%= t("dental.print.preview.type_heading.certificate") %></h2>
    <p class="mt-2 text-sm text-gray-600"><%= t("dental.print.templates.certificate.visit_label") %> <%= visit_id %></p>
  </header>

  <div class="space-y-5 text-base leading-relaxed text-gray-900">
    <p>
      <%= t("dental.print.templates.certificate.statement_1") %>
      <strong><%= data[:patient_name].presence || "________________" %></strong>
      (HN: <strong><%= data[:patient_hn].presence || "-" %></strong>)
      <%= t("dental.print.templates.certificate.statement_2") %>
    </p>

    <p>
      <%= t("dental.print.templates.certificate.visit_date") %>:
      <strong><%= data[:visit_date].presence || "-" %></strong>
    </p>

    <p>
      <%= t("dental.print.templates.certificate.service") %>:
      <strong><%= data[:service].presence || "-" %></strong>
    </p>

    <p>
      <%= t("dental.print.templates.certificate.issued_note") %>
    </p>

    <div class="mt-14 grid grid-cols-2 gap-10">
      <div>
        <p class="text-sm text-gray-600"><%= t("dental.print.templates.certificate.authorized_dentist") %></p>
        <span class="print-signature-line"></span>
      </div>
      <div>
        <p class="text-sm text-gray-600"><%= t("dental.print.templates.certificate.official_stamp") %></p>
        <span class="print-signature-line"></span>
      </div>
    </div>
  </div>
</section>
