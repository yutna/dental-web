<section class="rounded-md border border-gray-300 bg-white p-8 shadow-sm print:border-none print:shadow-none">
  <header class="print-header">
    <h2 class="text-2xl font-bold text-gray-900">
      <%= t("dental.print.preview.type_heading.treatment_summary") %>
    </h2>
    <p class="mt-2 text-sm text-gray-600">
      <%= t("dental.print.templates.treatment_summary.visit_label") %>: <strong><%= visit_id %></strong>
      <% if data[:patient_hn].present? %>
        | <%= t("dental.print.templates.treatment_summary.hn_label") %>: <strong><%= data[:patient_hn] %></strong>
      <% end %>
      <% if data[:patient_name].present? %>
        | <strong><%= data[:patient_name] %></strong>
      <% end %>
    </p>
  </header>

  <div class="space-y-6">
    <section class="print-avoid-break">
      <h3 class="mb-2 text-base font-semibold text-gray-900"><%= t("dental.print.templates.treatment_summary.diagnosis") %></h3>
      <p class="min-h-12 rounded-md border border-gray-200 bg-gray-50 p-3 text-sm text-gray-700">
        <%= data.dig(:screening, "preliminary_findings").presence || "-" %>
      </p>
    </section>

    <section class="print-avoid-break">
      <h3 class="mb-2 text-base font-semibold text-gray-900"><%= t("dental.print.templates.treatment_summary.procedures") %></h3>
      <table class="print-table">
        <thead>
          <tr>
            <th><%= t("dental.print.templates.treatment_summary.table.code") %></th>
            <th><%= t("dental.print.templates.treatment_summary.table.tooth") %></th>
            <th><%= t("dental.print.templates.treatment_summary.table.surface") %></th>
            <th><%= t("dental.print.templates.treatment_summary.table.qty") %></th>
          </tr>
        </thead>
        <tbody>
          <% if data[:procedures].present? %>
            <% data[:procedures].each do |procedure| %>
              <tr>
                <td><%= procedure[:procedure_item_code] %></td>
                <td><%= procedure[:tooth_code].presence || "-" %></td>
                <td><%= Array(procedure[:surface_codes]).join(", ").presence || "-" %></td>
                <td><%= procedure[:quantity] %></td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="text-center">-</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>

    <section class="print-avoid-break">
      <h3 class="mb-2 text-base font-semibold text-gray-900"><%= t("dental.print.templates.treatment_summary.billing_items") %></h3>
      <table class="print-table">
        <thead>
          <tr>
            <th><%= t("dental.print.templates.treatment_summary.billing_table.item") %></th>
            <th><%= t("dental.print.templates.treatment_summary.billing_table.qty") %></th>
            <th><%= t("dental.print.templates.treatment_summary.billing_table.unit_price") %></th>
            <th><%= t("dental.print.templates.treatment_summary.billing_table.amount") %></th>
          </tr>
        </thead>
        <tbody>
          <% if data[:line_items].present? %>
            <% data[:line_items].each do |item| %>
              <tr>
                <td><%= item[:item_name] %> (<%= item[:item_code] %>)</td>
                <td><%= item[:quantity] %></td>
                <td><%= number_with_precision(item[:unit_price] || 0, precision: 2) %></td>
                <td><%= number_with_precision(item[:amount] || 0, precision: 2) %></td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="text-center">-</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>

    <section class="print-avoid-break">
      <h3 class="mb-2 text-base font-semibold text-gray-900"><%= t("dental.print.templates.treatment_summary.medications") %></h3>
      <p class="min-h-12 rounded-md border border-gray-200 bg-gray-50 p-3 text-sm text-gray-700">
        <%= data.dig(:medication, "note").presence || "-" %>
      </p>
    </section>

    <section class="mt-8 grid grid-cols-2 gap-8">
      <div>
        <p class="text-sm text-gray-600"><%= t("dental.print.templates.treatment_summary.dentist_signature") %></p>
        <span class="print-signature-line"></span>
      </div>
      <div>
        <p class="text-sm text-gray-600"><%= t("dental.print.templates.treatment_summary.stamp") %></p>
        <span class="print-signature-line"></span>
      </div>
    </section>
  </div>
</section>
