<% content_for :title, t("dental.print.forbidden.title") %>
<% content_for :print_title, t("dental.print.forbidden.heading") %>

<section class="mx-auto max-w-3xl rounded-xl border border-red-200 bg-red-50 p-8">
  <h2 class="text-2xl font-bold text-red-900">403 Forbidden</h2>
  <p class="mt-3 text-red-800"><%= t("dental.print.forbidden.message", visit_id: @visit_id, type: @type) %></p>

  <div class="mt-4 rounded-md border border-red-200 bg-white p-4 text-sm text-red-700">
    <p><strong><%= t("dental.print.forbidden.required_permission") %></strong> dental:print:read</p>
    <p><strong><%= t("dental.print.forbidden.audit_ref") %></strong> PRINT-DENY-2026-0410-09</p>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    <%= link_to t("dental.print.forbidden.back_to_visit"),
      dental_visit_path(id: @visit_id),
      class: "inline-flex items-center rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>

    <%= link_to t("dental.print.forbidden.request_access"),
      admin_root_path,
      class: "inline-flex items-center rounded-md border border-red-300 bg-white px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100" %>
  </div>
</section>
