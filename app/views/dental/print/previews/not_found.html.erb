<% content_for :title, t("dental.print.not_found.title") %>
<% content_for :print_title, t("dental.print.not_found.heading") %>

<section class="mx-auto max-w-3xl rounded-xl border border-amber-200 bg-amber-50 p-8">
  <h2 class="text-2xl font-bold text-amber-900">404</h2>
  <p class="mt-3 text-amber-800"><%= t("dental.print.not_found.message", type: @type) %></p>

  <div class="mt-6">
    <%= link_to t("dental.print.preview.back_to_visit"),
      dental_visit_path(id: @visit_id),
      class: "inline-flex items-center rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700" %>
  </div>
</section>
