<%# Top bar — sticky header with breadcrumbs, locale, theme, profile %>
<header class="z-app-sticky sticky top-0 flex h-16 shrink-0 items-center gap-4 border-b border-app-border-primary bg-app-surface-primary/95 px-4 backdrop-blur sm:px-6">
  <%# Mobile hamburger %>
  <button
    type="button"
    class="inline-flex items-center justify-center rounded-lg p-2 text-app-text-secondary transition hover:bg-app-surface-secondary hover:text-app-text-primary lg:hidden"
    data-action="sidebar#toggle"
    aria-label="<%= t("layouts.topbar.toggle_sidebar", default: "Toggle sidebar") %>"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
    </svg>
  </button>

  <%# Breadcrumbs %>
  <nav class="flex flex-1 items-center gap-2 text-sm" aria-label="<%= t("layouts.topbar.breadcrumb_label", default: "Breadcrumb") %>">
    <% breadcrumb_items.each_with_index do |crumb, idx| %>
      <% if idx > 0 %>
        <svg class="h-4 w-4 shrink-0 text-app-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      <% end %>
      <% if crumb[:path] && idx < breadcrumb_items.size - 1 %>
        <%= link_to crumb[:label], crumb[:path], class: "truncate text-app-text-tertiary transition hover:text-app-text-primary" %>
      <% else %>
        <span class="truncate font-medium text-app-text-primary"><%= crumb[:label] %></span>
      <% end %>
    <% end %>
  </nav>

  <%# Right actions %>
  <div class="flex items-center gap-2">
    <%# Locale switcher %>
    <div class="inline-flex items-center rounded-lg border border-app-border-primary bg-app-surface-secondary p-0.5">
      <% [:en, :th].each do |locale| %>
        <% active = I18n.locale.to_sym == locale %>
        <%= link_to locale.to_s.upcase,
          url_for(request.query_parameters.merge(locale: locale)),
          class: "rounded-md px-2 py-1 text-xs font-semibold transition #{active ? 'bg-app-brand-primary text-app-brand-inverse shadow-sm' : 'text-app-text-secondary hover:text-app-text-primary'}" %>
      <% end %>
    </div>

    <%# Theme toggle %>
    <div data-controller="theme">
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-lg p-2 text-app-text-secondary transition hover:bg-app-surface-secondary hover:text-app-text-primary"
        data-action="theme#cycle"
        title="<%= t("layouts.topbar.toggle_theme", default: "Toggle theme") %>"
      >
        <svg class="h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <svg class="hidden h-5 w-5 dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>
    </div>

    <%# Profile dropdown %>
    <% if signed_in? %>
      <div
        class="relative"
        data-controller="profile-menu"
        data-action="keydown.esc@window->profile-menu#close"
      >
        <button
          type="button"
          class="inline-flex items-center gap-2 rounded-lg p-1.5 transition hover:bg-app-surface-secondary"
          data-profile-menu-target="button"
          data-action="profile-menu#toggle"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-app-brand-primary text-xs font-semibold text-app-brand-inverse">
            <%= current_principal.display_name.to_s.first&.upcase || "U" %>
          </span>
          <span class="hidden text-left sm:block">
            <span class="block text-sm font-medium leading-none text-app-text-primary"><%= current_principal.display_name %></span>
          </span>
        </button>

        <div
          class="z-app-floating absolute right-0 mt-2 hidden w-64 rounded-xl border border-app-border-primary bg-app-surface-primary p-2 shadow-xl"
          data-profile-menu-target="menu"
          data-action="click->profile-menu#keepOpen"
          role="menu"
        >
          <div class="rounded-lg bg-app-surface-secondary px-3 py-2">
            <p class="text-sm font-semibold text-app-text-primary"><%= current_principal.display_name %></p>
            <p class="text-xs text-app-text-tertiary"><%= current_principal.email %></p>
          </div>

          <div class="mt-1 border-t border-app-border-primary pt-1">
            <%= button_to session_path, method: :delete, class: "flex w-full items-center gap-2 rounded-lg px-3 py-2 text-sm text-app-text-secondary transition hover:bg-app-surface-secondary hover:text-app-text-primary", role: "menuitem" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
              </svg>
              <%= t("layouts.topbar.sign_out", default: "Sign out") %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</header>
