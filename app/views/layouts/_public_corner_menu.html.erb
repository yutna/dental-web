<div
  class="fixed right-4 top-4 z-40"
  data-controller="profile-menu theme"
  data-profile-menu-theme-saved-message-value="<%= t("public_menu.theme.saved") %>"
  data-theme-light-label-value="<%= t("public_menu.theme.modes.light") %>"
  data-theme-dark-label-value="<%= t("public_menu.theme.modes.dark") %>"
  data-action="keydown.esc@window->profile-menu#close"
>
  <button
    type="button"
    class="inline-flex items-center gap-2 rounded-xl border border-app-border-primary bg-app-surface-primary/95 px-3 py-2 text-sm font-semibold text-app-text-primary shadow-sm backdrop-blur transition hover:bg-app-surface-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-app-brand-primary"
    data-profile-menu-target="button"
    data-action="profile-menu#toggle"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls="public-corner-menu"
  >
    <span aria-hidden="true">☰</span>
    <span><%= t("public_menu.open") %></span>
  </button>

  <div
    id="public-corner-menu"
    class="absolute right-0 mt-2 hidden w-72 rounded-2xl border border-app-border-primary bg-app-surface-primary p-4 shadow-xl"
    data-profile-menu-target="menu"
    data-action="click->profile-menu#keepOpen keydown->profile-menu#onMenuKeydown"
    role="menu"
  >
    <div class="border-b border-app-border-primary pb-3">
      <p class="text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("public_menu.theme.label") %></p>
      <fieldset class="mt-2 space-y-2">
        <% ["light", "dark", "system"].each do |mode| %>
          <label class="flex cursor-pointer items-center gap-2 rounded-lg px-2 py-1 text-sm text-app-text-secondary transition hover:bg-app-surface-secondary hover:text-app-text-primary">
            <input
              type="radio"
              name="public-theme-mode"
              value="<%= mode %>"
              class="form-radio border-app-border-primary text-app-brand-primary focus:ring-app-brand-primary"
              data-action="change->theme#selectMode"
              <%= "checked" if mode == "system" %>
            >
            <span><%= t("public_menu.theme.modes.#{mode}") %></span>
          </label>
        <% end %>
      </fieldset>
      <p class="mt-2 text-xs text-app-text-tertiary">
        <%= t("public_menu.theme.resolved_label") %>
        <span data-theme-target="resolvedLabel" class="font-semibold text-app-text-secondary"></span>
      </p>
    </div>

    <div class="pt-3">
      <p class="text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("public_menu.language.label") %></p>
      <div class="mt-2 inline-flex items-center rounded-xl border border-app-border-primary bg-app-surface-secondary p-1">
        <% [ :en, :th ].each do |locale| %>
          <% active = I18n.locale.to_sym == locale %>
          <%= link_to t("public_menu.language.#{locale == :en ? :english : :thai}"), url_for(locale: locale), class: ["rounded-lg px-3 py-1 text-xs font-semibold transition", (active ? "bg-app-brand-primary text-app-brand-inverse" : "text-app-text-secondary hover:bg-app-surface-primary hover:text-app-text-primary")].join(" "), role: "menuitem" %>
        <% end %>
      </div>
    </div>

    <p class="mt-3 hidden text-xs text-app-text-secondary" data-profile-menu-target="announcement" aria-live="polite"></p>
  </div>
</div>
