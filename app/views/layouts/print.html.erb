<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "print", media: "all", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-gray-900 print:bg-white print:text-black">
    <%# On-screen controls — hidden when printing %>
    <header class="print-hide sticky top-0 z-10 border-b border-gray-200 bg-white px-6 py-3">
      <div class="mx-auto max-w-5xl space-y-3">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h1 class="text-lg font-semibold text-gray-900"><%= content_for(:print_title) || t("dental.print.preview.heading") %></h1>
            <% if content_for?(:print_subtitle) %>
              <p class="mt-1 text-xs tracking-wide text-gray-500"><%= yield :print_subtitle %></p>
            <% end %>
          </div>

          <div class="flex items-center gap-2">
            <% if @print_shell_state == "preview" %>
              <%# Print actions %>
              <button onclick="window.print()"
                class="inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-4 py-1.5 text-sm font-medium text-white transition hover:bg-blue-700">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                </svg>
                <%= t("dental.print.preview.print_button") %>
              </button>

              <button onclick="window.print()"
                class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50">
                <%= t("dental.print.preview.export_pdf") %>
              </button>
            <% end %>

            <%# Back to visit %>
            <%= link_to t("dental.print.preview.back_to_visit"),
              dental_visit_path(id: @visit_id),
              class: "inline-flex items-center rounded-md border border-gray-300 bg-white px-4 py-1.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50" %>

            <%# Language toggle (rightmost) %>
            <div class="ml-2 flex items-center rounded-md border border-gray-200 bg-gray-50 p-0.5">
              <% %w[en th].each do |lang| %>
                <% active = I18n.locale.to_s == lang %>
                <%= link_to lang.upcase,
                  url_for(locale: lang),
                  class: "rounded px-3 py-1.5 text-sm font-medium transition #{active ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-200'}",
                  data: { turbo_action: "replace" } %>
              <% end %>
            </div>
          </div>
        </div>

        <% if @print_shell_state == "preview" %>
          <%# Watermark mode panel (separate lower panel) %>
          <div class="relative rounded-lg border border-gray-200 bg-gray-50 px-3 py-2" style="position: relative;">
            <span class="text-xs font-semibold uppercase tracking-wide text-gray-500" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%);">Watermark</span>

            <div class="flex justify-end" style="display: flex; justify-content: flex-end;">
              <div class="flex items-center rounded-md border border-gray-200 bg-white p-0.5" aria-label="Watermark mode">
                <% {
                  "provisional" => t("dental.print.preview.watermark.provisional"),
                  "internal" => t("dental.print.preview.watermark.internal"),
                  "final" => t("dental.print.preview.watermark.final")
                }.each do |mode, label| %>
                  <% active = @watermark_mode == mode %>
                  <%= link_to label,
                    url_for(watermark: mode),
                    class: "rounded px-2 py-1 text-xs font-medium transition #{active ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-200'}",
                    data: { turbo_action: "replace" } %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </header>

    <%# Printable page area %>
    <main class="print-page mx-auto my-8 max-w-5xl px-6 print:m-0 print:max-w-none print:p-0">
      <%= yield %>
    </main>
  </body>
</html>
