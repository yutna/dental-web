<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= javascript_tag nonce: true do %>
      (() => {
        const storageKey = "theme-preference";
        const validModes = [ "light", "dark", "system" ];
        const root = document.documentElement;
        const systemTheme = () => window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const storedMode = localStorage.getItem(storageKey);
        const mode = validModes.includes(storedMode) ? storedMode : "system";
        const resolvedTheme = mode === "system" ? systemTheme() : mode;

        root.dataset.themeMode = mode;
        root.dataset.theme = resolvedTheme;
        root.classList.toggle("dark", resolvedTheme === "dark");
      })();
    <% end %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-app-surface-primary text-app-text-primary transition-colors">
    <% flashes = flash.to_hash.slice("notice", "alert") %>
    <% if flashes.any? %>
      <section
        class="flash-toast-viewport z-app-toast fixed right-3 top-24 w-[calc(100%-1.5rem)] max-w-104 sm:right-4 sm:top-24"
        data-controller="flash-toast"
        data-action="keydown.esc@window->flash-toast#dismissLatest"
        data-flash-toast-default-duration-value="4500"
        data-flash-toast-max-visible-value="3"
        data-flash-toast-swipe-threshold-value="72"
        aria-live="polite"
        aria-label="Notifications"
      >
        <ol class="space-y-2" role="list">
          <% flashes.each do |kind, message| %>
            <% next if message.blank? %>
            <% success = kind.to_s == "notice" %>
            <% border_class = success ? "border-border-semantic-success-primary" : "border-border-semantic-error-primary" %>
            <% bg_class = success ? "bg-bg-semantic-success-default" : "bg-bg-semantic-error-default" %>
            <% text_class = success ? "text-text-semantic-success-primary" : "text-text-semantic-error-primary" %>
            <% timeout = success ? 4500 : 7000 %>

            <li
              class="flash-toast group pointer-events-auto overflow-hidden rounded-xl border <%= border_class %> <%= bg_class %> <%= text_class %> shadow-lg"
              data-flash-toast-target="toast"
              data-timeout="<%= timeout %>"
              data-action="mouseenter->flash-toast#pause mouseleave->flash-toast#resume focusin->flash-toast#pause focusout->flash-toast#resume touchstart->flash-toast#touchStart touchmove->flash-toast#touchMove touchend->flash-toast#touchEnd touchcancel->flash-toast#touchCancel"
              role="<%= success ? "status" : "alert" %>"
            >
              <div class="flex items-start gap-3 px-4 py-3">
                <p class="min-w-0 flex-1 text-sm font-medium"><%= message %></p>
                <button
                  type="button"
                  class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-current/25 bg-transparent text-base leading-none transition hover:bg-black/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-app-brand-primary"
                  data-action="flash-toast#dismiss"
                  aria-label="<%= t("app.flash.dismiss") %>"
                >
                  <span aria-hidden="true">×</span>
                </button>
              </div>
              <div class="flash-toast-progress" data-flash-toast-target="progress"></div>
            </li>
          <% end %>
        </ol>
      </section>
    <% end %>

    <%= render "layouts/public_corner_menu" unless signed_in? %>

    <%= yield %>
  </body>
</html>
