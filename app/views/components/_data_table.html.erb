<%# Data table component — sortable columns, row actions slot, empty state, loading skeleton
  Locals:
    columns:   Array of { key:, label:, sortable: (bool), align: ("left"|"center"|"right"), class: (optional) }
    rows:      Array of hashes keyed by column keys, plus optional :_actions (raw HTML)
    sort_key:  Current sort column key (optional)
    sort_dir:  Current sort direction "asc"|"desc" (optional)
    empty_title:       Title for empty state (optional)
    empty_description: Description for empty state (optional)
    loading:   Show skeleton loading state (optional, default false)
    table_id:  DOM id for the table wrapper (optional)
%>
<% columns ||= [] %>
<% rows ||= [] %>
<% sort_key ||= nil %>
<% sort_dir ||= "asc" %>
<% empty_title ||= t("components.data_table.no_data") %>
<% empty_description ||= nil %>
<% loading ||= false %>
<% table_id ||= nil %>

<div<%= %( id="#{table_id}") if table_id %> class="overflow-hidden rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm" data-controller="data-table">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-app-border-primary">
      <thead class="bg-app-surface-secondary">
        <tr>
          <% columns.each do |col| %>
            <% align_class = { "center" => "text-center", "right" => "text-right" }.fetch(col[:align].to_s, "text-left") %>
            <th scope="col" class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-app-text-tertiary <%= align_class %> <%= col[:class] %>">
              <% if col[:sortable] %>
                <button type="button"
                        class="group inline-flex items-center gap-1"
                        data-action="data-table#sort"
                        data-data-table-key-param="<%= col[:key] %>"
                        data-data-table-dir-param="<%= sort_key.to_s == col[:key].to_s && sort_dir == 'asc' ? 'desc' : 'asc' %>">
                  <%= col[:label] %>
                  <span class="ml-0.5 flex flex-col text-app-text-tertiary/50 group-hover:text-app-text-secondary">
                    <% if sort_key.to_s == col[:key].to_s %>
                      <svg class="h-3.5 w-3.5 text-app-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <% if sort_dir == "asc" %>
                          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5"/>
                        <% else %>
                          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
                        <% end %>
                      </svg>
                    <% else %>
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15 12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9"/>
                      </svg>
                    <% end %>
                  </span>
                </button>
              <% else %>
                <%= col[:label] %>
              <% end %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary">
        <% if loading %>
          <% 5.times do %>
            <tr>
              <% columns.each do %>
                <td class="px-4 py-3">
                  <div class="h-4 w-3/4 rounded bg-app-surface-secondary skeleton-shimmer"></div>
                </td>
              <% end %>
            </tr>
          <% end %>
        <% elsif rows.empty? %>
          <tr>
            <td colspan="<%= columns.size %>" class="px-4 py-0">
              <%= render "components/empty_state", title: empty_title, description: empty_description %>
            </td>
          </tr>
        <% else %>
          <% rows.each do |row| %>
            <tr class="transition-colors hover:bg-app-surface-secondary/50" data-data-table-target="row">
              <% columns.each do |col| %>
                <% align_class = { "center" => "text-center", "right" => "text-right" }.fetch(col[:align].to_s, "text-left") %>
                <td class="whitespace-nowrap px-4 py-3 text-sm text-app-text-primary <%= align_class %> <%= col[:class] %>">
                  <%= row[col[:key]] %>
                </td>
              <% end %>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if rows.any? && block_given? %>
    <div class="border-t border-app-border-primary bg-app-surface-secondary px-4 py-3 text-xs text-app-text-tertiary">
      <%= yield %>
    </div>
  <% end %>
</div>
