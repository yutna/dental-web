<%# Filter bar component — search input, dropdown filters, apply/reset
  Locals:
    url:          Form action URL
    turbo_frame:  Turbo frame target id (optional)
    method:       HTTP method (default "get")
    search_name:  Name attribute for search field (default "q")
    search_value: Current search value (optional)
    search_placeholder: Placeholder text (optional)
  Block: additional filter fields (selects, date pickers, etc.)
%>
<% turbo_frame ||= nil %>
<% method ||= "get" %>
<% search_name ||= "q" %>
<% search_value ||= nil %>
<% search_placeholder ||= t("components.filter_bar.search_placeholder") %>

<div data-controller="filter-bar">
  <%= form_with url:, method:, data: { turbo_frame:, filter_bar_target: "form", action: "filter-bar#submit" }.compact_blank, class: "flex flex-col gap-3 sm:flex-row sm:items-end" do |f| %>
    <%# Search field %>
    <div class="relative flex-1">
      <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
        <svg class="h-4 w-4 text-app-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
        </svg>
      </div>
      <input
        type="search"
        name="<%= search_name %>"
        value="<%= search_value %>"
        placeholder="<%= search_placeholder %>"
        class="block w-full rounded-lg border border-app-border-primary bg-app-surface-primary py-2 pl-10 pr-3 text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-1 focus:ring-app-brand-primary"
        data-filter-bar-target="search"
        data-action="input->filter-bar#debounceSubmit"
        autocomplete="off"
      />
    </div>

    <%# Additional filter slots from block %>
    <% if block_given? %>
      <div class="flex flex-wrap items-end gap-2">
        <%= yield %>
      </div>
    <% end %>

    <%# Actions %>
    <div class="flex shrink-0 items-center gap-2">
      <button type="submit" class="inline-flex items-center rounded-lg bg-app-brand-primary px-3 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active">
        <%= t("components.filter_bar.apply") %>
      </button>
      <button type="button" class="inline-flex items-center rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm font-medium text-app-text-secondary transition hover:bg-app-surface-secondary" data-action="filter-bar#reset">
        <%= t("components.filter_bar.reset") %>
      </button>
    </div>
  <% end %>
</div>
