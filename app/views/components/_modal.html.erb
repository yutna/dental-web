<%# Modal shell component — Use with Stimulus modal controller
  Locals: id: (unique DOM id), title:, size: (optional "sm"|"md"|"lg"|"xl", default "md") %>
<% size ||= "md" %>
<% size_class = { "sm" => "max-w-sm", "md" => "max-w-lg", "lg" => "max-w-2xl", "xl" => "max-w-4xl" }.fetch(size, "max-w-lg") %>

<div<%= " id=\"#{id}\"".html_safe if local_assigns[:id] %> data-controller="modal" data-action="keydown.esc@window->modal#closeOnEsc">
  <%# Backdrop %>
  <div data-modal-target="backdrop" class="fixed inset-0 z-app-modal-backdrop hidden bg-black/50 transition-opacity"></div>

  <%# Panel %>
  <div data-modal-target="panel" class="fixed inset-0 z-app-modal hidden overflow-y-auto" data-action="click->modal#closeOnBackdrop">
    <div class="flex min-h-full items-center justify-center p-4">
      <div
        data-modal-content
        class="w-full scale-95 transform rounded-2xl border border-app-border-primary bg-app-surface-primary opacity-0 shadow-xl transition-all duration-150 <%= size_class %>"
      >
        <%# Header %>
        <div class="flex items-center justify-between border-b border-app-border-primary px-6 py-4">
          <h2 class="text-lg font-semibold text-app-text-primary"><%= title %></h2>
          <button
            type="button"
            class="rounded-lg p-1.5 text-app-text-tertiary transition hover:bg-app-surface-secondary hover:text-app-text-primary"
            data-action="modal#close"
            aria-label="Close"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <%# Body %>
        <div class="px-6 py-4">
          <%= yield %>
        </div>
      </div>
    </div>
  </div>
</div>
