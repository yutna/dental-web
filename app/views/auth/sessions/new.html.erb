<% content_for :title, t("auth.sessions.title") %>

<main class="flex min-h-dvh">
  <%# Brand panel — hidden on mobile %>
  <div class="hidden w-1/2 flex-col justify-between bg-app-brand-primary p-12 lg:flex">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/20">
        <svg class="h-6 w-6 text-app-brand-inverse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
        </svg>
      </div>
      <span class="text-lg font-bold text-app-brand-inverse"><%= t("app.name") %></span>
    </div>

    <div class="max-w-md">
      <h2 class="text-3xl font-bold leading-tight text-app-brand-inverse"><%= t("auth.sessions.brand_headline") %></h2>
      <p class="mt-4 text-base text-app-brand-inverse/80"><%= t("auth.sessions.brand_description") %></p>
    </div>

    <p class="text-sm text-app-brand-inverse/60"><%= t("app.name") %> · v1.0</p>
  </div>

  <%# Login form panel %>
  <div class="flex flex-1 items-center justify-center px-6 py-10">
    <section class="w-full max-w-md space-y-8">
      <%# Mobile logo %>
      <div class="flex items-center gap-3 lg:hidden">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-app-brand-primary">
          <svg class="h-6 w-6 text-app-brand-inverse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <span class="text-lg font-bold text-app-text-primary"><%= t("app.name") %></span>
      </div>

      <header>
        <h1 class="text-2xl font-bold tracking-tight text-app-text-primary"><%= t("auth.sessions.heading") %></h1>
        <p class="mt-2 text-sm text-app-text-secondary"><%= t("auth.sessions.description") %></p>
      </header>

      <% if @auth_error.present? %>
        <div class="rounded-xl border border-border-semantic-error-primary bg-bg-semantic-error-default px-4 py-3 text-sm text-text-semantic-error-primary" role="alert">
          <%= @auth_error %>
        </div>
      <% end %>

      <%= form_with url: session_path, method: :post, class: "space-y-5" do %>
        <div>
          <label for="username" class="block text-sm font-medium text-app-text-secondary"><%= t("auth.sessions.username_label") %></label>
          <input id="username" name="username" type="text" required autocomplete="username" value="<%= @username %>"
                 class="form-input mt-1.5 block w-full rounded-lg border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-app-text-secondary"><%= t("auth.sessions.password_label") %></label>
          <input id="password" name="password" type="password" required autocomplete="current-password"
                 class="form-input mt-1.5 block w-full rounded-lg border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary">
        </div>

        <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-app-brand-primary px-4 py-2.5 text-sm font-semibold text-app-brand-inverse transition hover:bg-app-brand-active">
          <%= t("auth.sessions.submit") %>
        </button>
      <% end %>

      <p class="text-center text-xs text-app-text-tertiary"><%= t("auth.sessions.demo_hint") %></p>
    </section>
  </div>
</main>
