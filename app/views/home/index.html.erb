<% content_for :title, t("home.title") %>
<% set_breadcrumbs({ label: t("layouts.sidebar.nav.dashboard") }) %>

<div class="space-y-6 p-6">
  <% if params[:reason] == "workspace_denied" %>
    <section class="rounded-xl border border-border-semantic-error-primary bg-bg-semantic-error-default p-5 shadow-sm" role="alert" aria-live="assertive">
      <h2 class="text-base font-semibold text-text-semantic-error-primary"><%= t("home.permission_denied.title") %></h2>
      <p class="mt-2 text-sm text-text-semantic-error-primary/90"><%= t("home.permission_denied.description") %></p>
      <p class="mt-3 text-sm font-medium text-text-semantic-error-primary"><%= t("home.permission_denied.help") %></p>
    </section>
  <% end %>

  <header>
    <h1 class="text-2xl font-bold tracking-tight text-app-text-primary">
      <%= t("home.authenticated.heading", user: current_principal.display_name) %>
    </h1>
    <p class="mt-1 text-sm text-app-text-secondary"><%= t("home.authenticated.description") %></p>
  </header>

  <%# Quick-access cards %>
  <nav class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" aria-label="<%= t("home.authenticated.quick_access") %>">
    <%= link_to workspace_path, class: "group rounded-xl border border-app-border-primary bg-app-surface-primary p-6 shadow-sm transition hover:border-app-brand-primary hover:shadow-md" do %>
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-bg-semantic-info-default text-text-semantic-info-primary">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z"/>
        </svg>
      </div>
      <h2 class="mt-4 text-base font-semibold text-app-text-primary group-hover:text-app-brand-primary"><%= t("home.authenticated.workspace.heading") %></h2>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("home.authenticated.workspace.description") %></p>
    <% end %>

    <%= link_to dental_root_path, class: "group rounded-xl border border-app-border-primary bg-app-surface-primary p-6 shadow-sm transition hover:border-app-brand-primary hover:shadow-md" do %>
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-bg-semantic-success-default text-text-semantic-success-primary">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z"/>
        </svg>
      </div>
      <h2 class="mt-4 text-base font-semibold text-app-text-primary group-hover:text-app-brand-primary"><%= t("home.authenticated.dental.heading") %></h2>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("home.authenticated.dental.description") %></p>
    <% end %>

    <%= link_to admin_root_path, class: "group rounded-xl border border-app-border-primary bg-app-surface-primary p-6 shadow-sm transition hover:border-app-brand-primary hover:shadow-md" do %>
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-bg-semantic-warning-default text-text-semantic-warning-primary">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
        </svg>
      </div>
      <h2 class="mt-4 text-base font-semibold text-app-text-primary group-hover:text-app-brand-primary"><%= t("home.authenticated.admin.heading") %></h2>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("home.authenticated.admin.description") %></p>
    <% end %>
  </nav>
</div>
