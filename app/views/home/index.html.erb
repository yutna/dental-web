<% content_for :title, t("home.title") %>

<main class="mx-auto w-full max-w-5xl space-y-8 px-6 py-10">
  <% if params[:reason] == "workspace_denied" %>
    <section class="rounded-2xl border border-border-semantic-error-primary bg-bg-semantic-error-default p-5 shadow-sm" role="alert" aria-live="assertive">
      <h2 class="text-base font-semibold text-text-semantic-error-primary"><%= t("home.permission_denied.title") %></h2>
      <p class="mt-2 text-sm text-text-semantic-error-primary/90"><%= t("home.permission_denied.description") %></p>
      <p class="mt-3 text-sm font-medium text-text-semantic-error-primary"><%= t("home.permission_denied.help") %></p>
    </section>
  <% end %>

  <header class="space-y-3">
    <h1 class="text-3xl font-bold tracking-tight text-app-text-primary sm:text-4xl">
      <%= t("home.authenticated.heading", user: current_principal.display_name) %>
    </h1>
    <p class="max-w-2xl text-base text-app-text-secondary"><%= t("home.authenticated.description") %></p>
  </header>

  <section class="rounded-2xl border border-app-border-primary bg-app-surface-primary p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-app-text-primary"><%= t("home.authenticated.workspace.heading") %></h2>
    <p class="mt-2 max-w-3xl text-sm text-app-text-secondary"><%= t("home.authenticated.workspace.description") %></p>
    <div class="mt-4 flex flex-wrap gap-3">
      <%= link_to t("home.authenticated.workspace.access_link"), workspace_path, class: "inline-flex items-center rounded-md bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
      <%= link_to t("home.authenticated.workspace.manage_link"), admin_root_path, class: "inline-flex items-center rounded-md border border-app-border-primary bg-app-surface-primary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
    </div>
  </section>
</main>
