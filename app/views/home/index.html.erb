<% content_for :title, t("home.title") %>

<main class="mx-auto w-full max-w-5xl space-y-8 px-6 py-10">
  <header class="space-y-3">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"><%= t("home.heading") %></h1>
    <p class="max-w-2xl text-base text-slate-600"><%= t("home.description") %></p>
  </header>

  <section class="rounded-2xl border border-indigo-100 bg-gradient-to-r from-indigo-50 via-sky-50 to-emerald-50 p-6 shadow-sm">
    <span class="inline-flex items-center rounded-full bg-indigo-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
      <%= t("home.tailwind_demo.badge") %>
    </span>
    <h2 class="mt-4 text-xl font-semibold text-slate-900"><%= t("home.tailwind_demo.heading") %></h2>
    <p class="mt-2 text-sm text-slate-700"><%= t("home.tailwind_demo.description") %></p>

    <div class="mt-5 flex flex-wrap gap-2 text-xs font-medium text-slate-700">
      <span class="rounded-full bg-white/80 px-3 py-1 ring-1 ring-slate-200"><%= t("home.tailwind_demo.chips.gradients") %></span>
      <span class="rounded-full bg-white/80 px-3 py-1 ring-1 ring-slate-200"><%= t("home.tailwind_demo.chips.rounded") %></span>
      <span class="rounded-full bg-white/80 px-3 py-1 ring-1 ring-slate-200"><%= t("home.tailwind_demo.chips.responsive") %></span>
    </div>
  </section>

  <nav aria-label="<%= t("home.language_switcher_label") %>" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white p-1 shadow-sm">
    <%= link_to t("home.languages.english"), url_for(locale: :en), class: "rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-slate-900" %>
    <%= link_to t("home.languages.thai"), url_for(locale: :th), class: "rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100 hover:text-slate-900" %>
  </nav>
</main>
