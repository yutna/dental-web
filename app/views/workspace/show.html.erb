<% content_for :title, t("workspace.title") %>
<% set_breadcrumbs({ label: t("layouts.sidebar.nav.dashboard"), path: root_path }, { label: t("workspace.heading") }) %>

<div class="space-y-6 p-6">
  <%# Summary cards %>
  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <%= render "components/stat_card", label: t("workspace.summary.total"), value: @result[:summary][:total],
      icon: '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>' %>
    <%= render "components/stat_card", label: t("workspace.summary.in_progress"), value: @result[:summary][:in_progress], color: "info",
      icon: '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>' %>
    <%= render "components/stat_card", label: t("workspace.summary.ready"), value: @result[:summary][:ready], color: "success",
      icon: '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>' %>
    <%= render "components/stat_card", label: t("workspace.summary.waiting_payment"), value: @result[:summary][:waiting_payment], color: "warning",
      icon: '<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>' %>
  </section>

  <%# Queue section %>
  <section
    class="rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm"
    data-controller="frame-loading queue-polling"
    data-queue-polling-frame-value="appointments_grid"
    data-queue-polling-interval-value="30000"
  >
    <div class="flex flex-wrap items-start justify-between gap-3 border-b border-app-border-primary px-5 py-4">
      <div>
        <h2 class="text-lg font-semibold text-app-text-primary"><%= t("workspace.queue.heading") %></h2>
        <p class="text-sm text-app-text-secondary"><%= t("workspace.queue.description") %></p>
      </div>
      <div class="flex gap-2">
        <%= form_with url: dental_visit_sync_appointments_path, method: :post, data: { turbo: false }, class: "inline-flex" do %>
          <button type="submit" class="inline-flex h-9 items-center gap-1.5 rounded-lg border border-app-border-primary bg-app-surface-primary px-3 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/></svg>
            <%= t("workspace.queue.sync_appointments") %>
          </button>
        <% end %>
        <%= link_to t("workspace.table.retry"), workspace_path(search: @result.dig(:filters, :search), status: @result.dig(:filters, :status), source: @result.dig(:filters, :source)), class: "inline-flex h-9 items-center rounded-lg border border-app-border-primary bg-app-surface-primary px-3 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary", data: { turbo_frame: "appointments_grid" } %>
      </div>
    </div>

    <%# Filters %>
    <div class="border-b border-app-border-primary bg-app-surface-secondary/50 px-5 py-3">
      <%= form_with url: workspace_path, method: :get, class: "grid gap-3 md:grid-cols-[1fr_180px_180px_auto]", data: { turbo_frame: "appointments_grid", queue_polling_target: "filtersForm" } do %>
        <div>
          <label for="search" class="sr-only"><%= t("workspace.filters.search_label") %></label>
          <%= text_field_tag :search, @result[:filters][:search], id: "search", class: "form-input block w-full rounded-lg border-app-border-primary bg-app-surface-primary text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary", placeholder: t("workspace.filters.search_placeholder") %>
        </div>
        <div>
          <%= select_tag :status, options_for_select([[t("workspace.filters.all_statuses"), ""]] + @result[:status_options].map { |status| [t("workspace.statuses.#{status}"), status] }, @result[:filters][:status]), id: "status", class: "form-select block w-full rounded-lg border-app-border-primary bg-app-surface-primary text-sm text-app-text-primary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
        </div>
        <div>
          <%= select_tag :source, options_for_select([[t("workspace.filters.all_sources"), ""]] + @result[:source_options].map { |source| [t("workspace.sources.#{source}"), source] }, @result[:filters][:source]), id: "source", class: "form-select block w-full rounded-lg border-app-border-primary bg-app-surface-primary text-sm text-app-text-primary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
        </div>
        <div class="flex items-center gap-2">
          <button type="submit" class="inline-flex h-9 items-center rounded-lg bg-app-brand-primary px-4 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active">
            <%= t("workspace.filters.apply") %>
          </button>
          <%= link_to t("workspace.filters.reset"), workspace_path, class: "inline-flex h-9 items-center rounded-lg border border-app-border-primary bg-app-surface-primary px-3 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
        </div>
      <% end %>
    </div>

    <%# Loading skeleton %>
    <div data-frame-loading-target="skeleton" class="hidden space-y-2 p-5" aria-hidden="true">
      <div class="h-9 w-full rounded-md bg-app-surface-secondary skeleton-shimmer"></div>
      <div class="h-9 w-full rounded-md bg-app-surface-secondary skeleton-shimmer"></div>
      <div class="h-9 w-full rounded-md bg-app-surface-secondary skeleton-shimmer"></div>
    </div>

    <%# Data table %>
    <turbo-frame id="appointments_grid" data-frame-loading-target="frame" class="block">
      <%= render "appointments_grid", result: @result %>
    </turbo-frame>
  </section>
</div>
