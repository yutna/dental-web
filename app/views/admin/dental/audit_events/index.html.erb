<% content_for :title, t("admin.dental.audit_events.title") %>
<% set_breadcrumbs(
  { label: t("layouts.sidebar.nav.admin_dashboard"), path: admin_root_path },
  { label: t("layouts.sidebar.nav.audit_log") }
) %>

<div class="mx-auto w-full max-w-6xl space-y-6 px-6 py-10">
  <%= render "components/page_header", title: t("admin.dental.audit_events.heading"), description: t("admin.dental.audit_events.description") %>

  <section class="rounded-xl border border-app-border-primary bg-app-surface-primary p-4 shadow-sm">
    <%= form_with url: admin_dental_audit_events_path, method: :get, local: true, class: "grid gap-3 sm:grid-cols-3" do |f| %>
      <%= f.text_field :actor_id, value: @filters[:actor_id], placeholder: t("admin.dental.audit_events.filters.actor_id"), class: "rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
      <%= f.text_field :event_action, value: @filters[:event_action], placeholder: t("admin.dental.audit_events.filters.action"), class: "rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
      <%= f.text_field :resource_type, value: @filters[:resource_type], placeholder: t("admin.dental.audit_events.filters.resource_type"), class: "rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
      <%= f.text_field :from, value: @filters[:from], placeholder: t("admin.dental.audit_events.filters.from"), class: "rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
      <%= f.text_field :to, value: @filters[:to], placeholder: t("admin.dental.audit_events.filters.to"), class: "rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
      <div class="flex items-center gap-2">
        <%= f.number_field :limit, value: @filters[:limit] || 100, min: 1, max: 500, class: "w-24 rounded-lg border border-app-border-primary bg-app-surface-primary px-3 py-2 text-sm text-app-text-primary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
        <%= f.submit t("admin.dental.audit_events.filters.apply"), class: "inline-flex items-center rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
      </div>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
    <table class="min-w-full divide-y divide-app-border-primary text-sm">
      <thead class="bg-app-surface-secondary">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.audit_events.table.time") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.audit_events.table.actor") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.audit_events.table.action") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.audit_events.table.resource") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.audit_events.table.metadata") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary text-app-text-primary">
        <% if @audit_events.any? %>
          <% @audit_events.each do |event| %>
            <tr class="transition hover:bg-app-surface-secondary">
              <td class="whitespace-nowrap px-4 py-3 text-app-text-secondary"><%= l(event.created_at, format: :long) %></td>
              <td class="px-4 py-3"><%= event.actor_id %></td>
              <td class="px-4 py-3"><span class="inline-flex rounded-md bg-app-surface-secondary px-2 py-0.5 text-xs font-medium"><%= event.action %></span></td>
              <td class="px-4 py-3 text-app-text-secondary"><%= [event.resource_type, event.resource_id].compact.join("#") %></td>
              <td class="max-w-xs truncate px-4 py-3 font-mono text-xs text-app-text-tertiary"><%= event.metadata_json %></td>
            </tr>
          <% end %>
        <% else %>
          <tr><td colspan="5" class="px-4 py-10 text-center">
            <%= render "components/empty_state", title: t("admin.dental.audit_events.table.empty"), description: t("admin.dental.audit_events.description") %>
          </td></tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
