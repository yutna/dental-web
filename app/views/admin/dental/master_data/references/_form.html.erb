<%= form_with model: reference,
  url: reference.persisted? ? admin_dental_master_data_reference_path(reference) : admin_dental_master_data_references_path,
  class: "space-y-4" do |form| %>
  <div>
    <label class="block text-sm font-medium text-app-text-secondary"><%= t("admin.dental.references.table.code") %></label>
    <%= form.text_field :code, class: "form-input mt-1 block w-full" %>
  </div>

  <div>
    <label class="block text-sm font-medium text-app-text-secondary"><%= t("admin.dental.references.table.name") %></label>
    <%= form.text_field :name, class: "form-input mt-1 block w-full" %>
  </div>

  <label class="inline-flex items-center gap-2 text-sm text-app-text-secondary">
    <%= form.check_box :active %>
    <span><%= t("admin.clinic_services.form.active") %></span>
  </label>

  <div class="flex gap-2">
    <%= form.submit class: "inline-flex items-center rounded-md bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse" %>
    <%= link_to t("admin.clinic_services.form.cancel"), admin_dental_master_data_references_path, class: "inline-flex items-center rounded-md border border-app-border-primary bg-app-surface-primary px-4 py-2 text-sm font-medium text-app-text-primary" %>
  </div>
<% end %>
