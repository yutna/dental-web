<%= form_with model: coverage,
  url: coverage.persisted? ? admin_dental_master_data_coverage_path(coverage) : admin_dental_master_data_coverages_path,
  class: "space-y-4" do |form| %>
  <div>
    <label class="block text-sm font-medium text-app-text-secondary"><%= t("admin.dental.coverages.table.item") %></label>
    <%= form.collection_select :procedure_item_id, @procedure_items, :id, :code, {}, { class: "form-select mt-1 block w-full" } %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="block text-sm font-medium text-app-text-secondary"><%= t("admin.dental.coverages.table.eligibility") %></label>
      <%= form.text_field :eligibility_code, class: "form-input mt-1 block w-full" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-app-text-secondary">effective_from</label>
      <%= form.date_field :effective_from, class: "form-input mt-1 block w-full" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="block text-sm font-medium text-app-text-secondary"><%= t("admin.dental.coverages.table.price_opd") %></label>
      <%= form.number_field :price_opd, step: 0.01, min: 0, class: "form-input mt-1 block w-full" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-app-text-secondary"><%= t("admin.dental.coverages.table.price_ipd") %></label>
      <%= form.number_field :price_ipd, step: 0.01, min: 0, class: "form-input mt-1 block w-full" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="block text-sm font-medium text-app-text-secondary">copay_amount</label>
      <%= form.number_field :copay_amount, step: 0.01, min: 0, class: "form-input mt-1 block w-full" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-app-text-secondary">copay_percent</label>
      <%= form.number_field :copay_percent, step: 0.01, min: 0, max: 100, class: "form-input mt-1 block w-full" %>
    </div>
  </div>

  <%= form.hidden_field :lock_version %>

  <label class="inline-flex items-center gap-2 text-sm text-app-text-secondary">
    <%= form.check_box :active %>
    <span><%= t("admin.clinic_services.form.active") %></span>
  </label>

  <div class="flex gap-2">
    <%= form.submit class: "inline-flex items-center rounded-md bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse" %>
    <%= link_to t("admin.clinic_services.form.cancel"), admin_dental_master_data_coverages_path, class: "inline-flex items-center rounded-md border border-app-border-primary bg-app-surface-primary px-4 py-2 text-sm font-medium text-app-text-primary" %>
  </div>
<% end %>
