<% content_for :title, t("admin.dental.procedure_items.title") %>
<% set_breadcrumbs(
  { label: t("layouts.sidebar.nav.admin_dashboard"), path: admin_root_path },
  { label: t("layouts.sidebar.nav.procedure_items") }
) %>

<div class="mx-auto w-full max-w-6xl space-y-5 px-6 py-10">
  <%= render "components/page_header", title: t("admin.dental.procedure_items.heading"), description: t("admin.dental.procedure_items.description") do %>
    <%= link_to t("admin.dental.procedure_items.new"), new_admin_dental_master_data_procedure_item_path, class: "inline-flex items-center rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
  <% end %>

  <div class="overflow-hidden rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
    <table class="min-w-full divide-y divide-app-border-primary text-sm">
      <thead class="bg-app-surface-secondary">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.code") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.name") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.group") %></th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.price_opd") %></th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.price_ipd") %></th>
          <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.status") %></th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-app-text-secondary"><%= t("admin.dental.procedure_items.table.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary">
        <% if @procedure_items.empty? %>
          <tr><td colspan="7" class="px-4 py-10 text-center">
            <%= render "components/empty_state", title: t("admin.dental.procedure_items.table.empty"), description: t("admin.dental.procedure_items.description") do %>
              <%= link_to t("admin.dental.procedure_items.new"), new_admin_dental_master_data_procedure_item_path, class: "inline-flex items-center rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
            <% end %>
          </td></tr>
        <% else %>
          <% @procedure_items.each do |item| %>
            <tr class="transition hover:bg-app-surface-secondary">
              <td class="whitespace-nowrap px-4 py-3 font-medium text-app-text-primary"><%= item.code %></td>
              <td class="px-4 py-3 text-app-text-primary"><%= item.name %></td>
              <td class="px-4 py-3 text-app-text-secondary"><%= item.procedure_group.code %></td>
              <td class="whitespace-nowrap px-4 py-3 text-right tabular-nums text-app-text-secondary"><%= number_to_currency(item.price_opd, unit: "฿") %></td>
              <td class="whitespace-nowrap px-4 py-3 text-right tabular-nums text-app-text-secondary"><%= number_to_currency(item.price_ipd, unit: "฿") %></td>
              <td class="px-4 py-3 text-center">
                <% if item.active? %>
                  <span class="inline-flex items-center rounded-full bg-bg-semantic-success-default px-2 py-0.5 text-xs font-medium text-text-semantic-success-primary"><%= t("admin.clinic_services.status.active") %></span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-app-surface-secondary px-2 py-0.5 text-xs font-medium text-app-text-tertiary"><%= t("admin.clinic_services.status.inactive") %></span>
                <% end %>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                <div class="inline-flex gap-2">
                  <%= link_to t("admin.clinic_services.table.edit"), edit_admin_dental_master_data_procedure_item_path(item), class: "rounded-md border border-app-border-primary bg-app-surface-primary px-3 py-1.5 text-xs font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
                  <%= button_to t("admin.clinic_services.table.delete"), admin_dental_master_data_procedure_item_path(item), method: :delete, form: { data: { turbo_confirm: t("admin.clinic_services.confirm_delete") } }, class: "rounded-md border border-border-semantic-error-primary bg-bg-semantic-error-default px-3 py-1.5 text-xs font-medium text-text-semantic-error-primary transition hover:bg-bg-semantic-error-subtle" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
