<% content_for :title, t("admin.dental.procedure_items.title") %>

<main class="mx-auto w-full max-w-6xl space-y-5 px-6 py-10">
  <header class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-app-text-primary"><%= t("admin.dental.procedure_items.heading") %></h1>
      <p class="mt-1 text-sm text-app-text-secondary"><%= t("admin.dental.procedure_items.description") %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to t("admin.dental.procedure_items.back_to_dashboard"), admin_dental_root_path, class: "inline-flex items-center rounded-md border border-app-border-primary bg-app-surface-primary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
      <%= link_to t("admin.dental.procedure_items.new"), new_admin_dental_master_data_procedure_item_path, class: "inline-flex items-center rounded-md bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
    </div>
  </header>

  <div class="overflow-x-auto rounded-xl border border-app-border-primary bg-app-surface-primary">
    <table class="min-w-full divide-y divide-app-border-primary text-sm">
      <thead class="bg-app-surface-secondary">
        <tr>
          <th class="px-3 py-2 text-left font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.code") %></th>
          <th class="px-3 py-2 text-left font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.name") %></th>
          <th class="px-3 py-2 text-left font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.group") %></th>
          <th class="px-3 py-2 text-left font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.price_opd") %></th>
          <th class="px-3 py-2 text-left font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.price_ipd") %></th>
          <th class="px-3 py-2 text-left font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.status") %></th>
          <th class="px-3 py-2 text-right font-semibold text-app-text-secondary"><%= t("admin.dental.procedure_items.table.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary">
        <% if @procedure_items.empty? %>
          <tr>
            <td colspan="7" class="px-3 py-6 text-center text-app-text-tertiary"><%= t("admin.dental.procedure_items.table.empty") %></td>
          </tr>
        <% else %>
          <% @procedure_items.each do |item| %>
            <tr class="transition hover:bg-app-surface-secondary">
              <td class="px-3 py-2 text-app-text-primary"><%= item.code %></td>
              <td class="px-3 py-2 text-app-text-primary"><%= item.name %></td>
              <td class="px-3 py-2 text-app-text-secondary"><%= item.procedure_group.code %></td>
              <td class="px-3 py-2 text-app-text-secondary"><%= item.price_opd %></td>
              <td class="px-3 py-2 text-app-text-secondary"><%= item.price_ipd %></td>
              <td class="px-3 py-2 text-app-text-secondary"><%= item.active? ? t("admin.clinic_services.status.active") : t("admin.clinic_services.status.inactive") %></td>
              <td class="px-3 py-2 text-right">
                <div class="inline-flex gap-2">
                  <%= link_to t("admin.clinic_services.table.edit"), edit_admin_dental_master_data_procedure_item_path(item), class: "rounded-md border border-app-border-primary bg-app-surface-primary px-3 py-1.5 text-xs font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
                  <%= button_to t("admin.clinic_services.table.delete"), admin_dental_master_data_procedure_item_path(item), method: :delete, form: { data: { turbo_confirm: t("admin.clinic_services.confirm_delete") } }, class: "rounded-md border border-border-semantic-error-primary bg-bg-semantic-error-default px-3 py-1.5 text-xs font-medium text-text-semantic-error-primary transition hover:bg-bg-semantic-error-subtle" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</main>
