<% content_for :title, t("admin.dental.medication_profiles.title") %>

<div class="mx-auto w-full max-w-6xl space-y-5 px-6 py-10">
  <div class="flex items-center justify-between gap-4">
    <h1 class="text-2xl font-semibold text-app-text-primary"><%= t("admin.dental.medication_profiles.heading") %></h1>
    <%= link_to t("admin.dental.medication_profiles.new"), new_admin_dental_master_data_medication_profile_path, class: "inline-flex items-center rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
  </div>

  <div class="overflow-hidden rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
    <table class="min-w-full divide-y divide-app-border-primary text-sm">
      <thead class="bg-app-surface-secondary">
        <tr>
          <th class="px-4 py-3 text-left"><%= t("admin.dental.medication_profiles.table.code") %></th>
          <th class="px-4 py-3 text-left"><%= t("admin.dental.medication_profiles.table.name") %></th>
          <th class="px-4 py-3 text-left"><%= t("admin.dental.medication_profiles.table.category") %></th>
          <th class="px-4 py-3 text-left"><%= t("admin.dental.medication_profiles.table.status") %></th>
          <th class="px-4 py-3 text-right"><%= t("admin.dental.medication_profiles.table.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary">
        <% @medication_profiles.each do |profile| %>
          <tr>
            <td class="px-4 py-3 font-medium text-app-text-primary"><%= profile.code %></td>
            <td class="px-4 py-3 text-app-text-primary"><%= profile.name %></td>
            <td class="px-4 py-3 text-app-text-secondary"><%= profile.category %></td>
            <td class="px-4 py-3 text-app-text-secondary"><%= profile.active? ? t("admin.clinic_services.status.active") : t("admin.clinic_services.status.inactive") %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to t("admin.clinic_services.table.edit"), edit_admin_dental_master_data_medication_profile_path(profile), class: "rounded-md border border-app-border-primary bg-app-surface-primary px-3 py-1.5 text-xs font-medium text-app-text-primary" %>
              <%= button_to t("admin.clinic_services.table.delete"), admin_dental_master_data_medication_profile_path(profile), method: :delete, form: { class: "inline" }, class: "rounded-md border border-border-semantic-error-primary bg-bg-semantic-error-default px-3 py-1.5 text-xs font-medium text-text-semantic-error-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
