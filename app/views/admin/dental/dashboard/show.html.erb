<% content_for :title, t("admin.dental.dashboard.title") %>
<% set_breadcrumbs(
  { label: t("layouts.sidebar.nav.admin_dashboard"), path: admin_root_path },
  { label: t("layouts.sidebar.nav.dental_admin") }
) %>

<div class="space-y-6 p-6">
  <%= render "components/page_header", title: t("admin.dental.dashboard.heading"), description: t("admin.dental.dashboard.description") do %>
    <%= link_to t("admin.dental.dashboard.audit_events"), admin_dental_audit_events_path, class: "inline-flex items-center rounded-lg border border-app-border-primary bg-app-surface-primary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
    <%= link_to t("admin.dental.dashboard.manage_services"), admin_clinic_services_path, class: "inline-flex items-center rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
  <% end %>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%= render "components/stat_card", label: t("admin.dental.dashboard.kpis.master_resources"), value: @summary[:master_resources] %>
    <%= render "components/stat_card", label: t("admin.dental.dashboard.kpis.pending_approvals"), value: @summary[:pending_approvals] %>
    <%= render "components/stat_card", label: t("admin.dental.dashboard.kpis.sync_warnings"), value: @summary[:sync_warnings], color: "warning" %>
    <%= render "components/stat_card", label: t("admin.dental.dashboard.kpis.active_items"), value: @summary[:active_items], color: "success" %>
  </section>

  <section class="rounded-xl border border-app-border-primary bg-app-surface-primary p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-app-text-primary"><%= t("admin.dental.dashboard.breakdown.heading") %></h2>
    <dl class="mt-4 grid gap-3 sm:grid-cols-2">
      <div class="flex items-center justify-between rounded-lg bg-app-surface-secondary px-4 py-3 text-sm">
        <dt class="text-app-text-secondary"><%= t("admin.dental.dashboard.breakdown.procedure_groups") %></dt>
        <dd class="font-semibold text-app-text-primary"><%= @totals[:procedure_groups] %></dd>
      </div>
      <div class="flex items-center justify-between rounded-lg bg-app-surface-secondary px-4 py-3 text-sm">
        <dt class="text-app-text-secondary"><%= t("admin.dental.dashboard.breakdown.procedure_items") %></dt>
        <dd class="font-semibold text-app-text-primary"><%= @totals[:procedure_items] %></dd>
      </div>
      <div class="flex items-center justify-between rounded-lg bg-app-surface-secondary px-4 py-3 text-sm">
        <dt class="text-app-text-secondary"><%= t("admin.dental.dashboard.breakdown.medication_profiles") %></dt>
        <dd class="font-semibold text-app-text-primary"><%= @totals[:medication_profiles] %></dd>
      </div>
      <div class="flex items-center justify-between rounded-lg bg-app-surface-secondary px-4 py-3 text-sm">
        <dt class="text-app-text-secondary"><%= t("admin.dental.dashboard.breakdown.supply_items") %></dt>
        <dd class="font-semibold text-app-text-primary"><%= @totals[:supply_items] %></dd>
      </div>
    </dl>
  </section>
</div>
