<% content_for :title, t("admin.clinic_services.title") %>
<% set_breadcrumbs(
  { label: t("layouts.sidebar.nav.admin_dashboard"), path: admin_root_path },
  { label: t("layouts.sidebar.nav.clinic_services") }
) %>

<div class="space-y-6 p-6">
  <%= render "components/page_header", title: t("admin.clinic_services.heading"), description: t("admin.clinic_services.description") do %>
    <%= link_to t("admin.clinic_services.new"), new_admin_clinic_service_path, class: "inline-flex items-center gap-2 rounded-lg bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
  <% end %>

  <div class="overflow-hidden rounded-xl border border-app-border-primary bg-app-surface-primary shadow-sm">
    <table class="min-w-full divide-y divide-app-border-primary text-sm">
      <thead class="bg-app-surface-secondary">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("admin.clinic_services.table.code") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("admin.clinic_services.table.name") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("admin.clinic_services.table.duration") %></th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("admin.clinic_services.table.status") %></th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-app-text-tertiary"><%= t("admin.clinic_services.table.actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-app-border-primary">
        <% if @clinic_services.empty? %>
          <tr>
            <td colspan="5">
              <%= render "components/empty_state", title: t("admin.clinic_services.table.empty") %>
            </td>
          </tr>
        <% else %>
          <% @clinic_services.each do |clinic_service| %>
            <tr class="transition hover:bg-app-surface-secondary">
              <td class="whitespace-nowrap px-4 py-3 font-medium text-app-text-primary"><%= clinic_service.code %></td>
              <td class="px-4 py-3 text-app-text-primary"><%= clinic_service.name %></td>
              <td class="whitespace-nowrap px-4 py-3 text-app-text-secondary"><%= clinic_service.default_duration_minutes %> min</td>
              <td class="whitespace-nowrap px-4 py-3">
                <% if clinic_service.active? %>
                  <span class="inline-flex items-center rounded-full border border-border-semantic-success-primary bg-bg-semantic-success-default px-2 py-0.5 text-xs font-semibold text-text-semantic-success-primary"><%= t("admin.clinic_services.status.active") %></span>
                <% else %>
                  <span class="inline-flex items-center rounded-full border border-app-border-primary bg-app-surface-secondary px-2 py-0.5 text-xs font-semibold text-app-text-secondary"><%= t("admin.clinic_services.status.inactive") %></span>
                <% end %>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                <div class="inline-flex gap-2">
                  <%= link_to t("admin.clinic_services.table.edit"), edit_admin_clinic_service_path(clinic_service), class: "rounded-md border border-app-border-primary bg-app-surface-primary px-3 py-1.5 text-xs font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
                  <%= button_to t("admin.clinic_services.table.delete"), admin_clinic_service_path(clinic_service), method: :delete, form: { data: { turbo_confirm: t("admin.clinic_services.confirm_delete") } }, class: "rounded-md border border-border-semantic-error-primary bg-bg-semantic-error-default px-3 py-1.5 text-xs font-medium text-text-semantic-error-primary transition hover:bg-bg-semantic-error-subtle" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
