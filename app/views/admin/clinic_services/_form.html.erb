<%= form_with model: [ :admin, clinic_service ], class: "space-y-4" do |form| %>
  <% if clinic_service.errors.any? %>
    <div class="rounded-md border border-border-semantic-error-primary bg-bg-semantic-error-default px-4 py-3 text-sm text-text-semantic-error-primary">
      <p class="font-semibold"><%= t("admin.clinic_services.form.error_heading") %></p>
      <ul class="mt-1 list-inside list-disc">
        <% clinic_service.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label for="clinic_service_code" class="block text-sm font-medium text-app-text-secondary"><%= t("admin.clinic_services.form.code") %></label>
    <%= form.text_field :code, class: "form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
  </div>

  <div>
    <label for="clinic_service_name" class="block text-sm font-medium text-app-text-secondary"><%= t("admin.clinic_services.form.name") %></label>
    <%= form.text_field :name, class: "form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
  </div>

  <div>
    <label for="clinic_service_default_duration_minutes" class="block text-sm font-medium text-app-text-secondary"><%= t("admin.clinic_services.form.default_duration") %></label>
    <%= form.number_field :default_duration_minutes, min: 1, class: "form-input mt-1 block w-full border-app-border-primary bg-app-surface-primary text-app-text-primary placeholder:text-app-text-tertiary focus:border-app-brand-primary focus:ring-app-brand-primary" %>
  </div>

  <label class="inline-flex items-center gap-2 text-sm text-app-text-secondary">
    <%= form.check_box :active, class: "form-checkbox border-app-border-primary bg-app-surface-primary text-app-brand-primary focus:ring-app-brand-primary" %>
    <span><%= t("admin.clinic_services.form.active") %></span>
  </label>

  <div class="flex gap-2">
    <%= form.submit class: "inline-flex items-center rounded-md bg-app-brand-primary px-4 py-2 text-sm font-medium text-app-brand-inverse transition hover:bg-app-brand-active" %>
    <%= link_to t("admin.clinic_services.form.cancel"), admin_clinic_services_path, class: "inline-flex items-center rounded-md border border-app-border-primary bg-app-surface-primary px-4 py-2 text-sm font-medium text-app-text-primary transition hover:bg-app-surface-secondary" %>
  </div>
<% end %>
